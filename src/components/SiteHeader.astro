---
import { Image } from "astro:assets";
import logoIcon from "../assets/logo.png";
import titleText from "../assets/title-text.png";

const isHome = Astro.url.pathname === "/";
const homeHref = isHome ? "#top" : "/";
const sectionHref = (sectionId: string) =>
    isHome ? `#${sectionId}` : `/#${sectionId}`;
---

<header class="site-header container">
    <a href={homeHref} class="brand" aria-label="Station48 home">
        <Image
            src={logoIcon}
            alt="Station48 logo icon"
            class="brand-logo-icon"
        />
        <Image src={titleText} alt="Station48" class="brand-title-image" />
    </a>
    <nav aria-label="Main navigation">
        <ul class="nav-list">
            <li><a href={sectionHref("join")}>Join</a></li>
            <li><a href={sectionHref("features")}>Features</a></li>
            <li><a href={sectionHref("rules")}>Rules</a></li>
            <li><a href="/news">News</a></li>
            <li><a href={sectionHref("faq")}>FAQ</a></li>
        </ul>
    </nav>
</header>
